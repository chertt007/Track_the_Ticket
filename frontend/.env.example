# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.

# AWS Cognito — filled in after Terraform creates the Cognito User Pool
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_COGNITO_DOMAIN=tracktheticket.auth.us-east-1.amazoncognito.com

# API — filled in after TF-API deploys Lambda + API Gateway
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
