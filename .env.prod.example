# Prefix for Docker images in ghcr.io — must be lowercase
# Example: ghcr.io/johndoe/track-the-ticket
IMAGE_PREFIX=ghcr.io/YOUR_GITHUB_USERNAME/track-the-ticket

DATABASE_PATH=/data/tracktheticket.db
SCREENSHOTS_DIR=/data/screenshots

FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-sa.json

ANTHROPIC_API_KEY=sk-ant-...

# Used by airline_url_finder agent to look up airline website URLs (browser-use + Gemini).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

TELEGRAM_BOT_TOKEN=...
TELEGRAM_BOT_USERNAME=track_the_ticket_bot
TELEGRAM_INTERNAL_SECRET=replace-with-openssl-rand-hex-32
API_BASE_URL=http://api:8000
