# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/

# ── Python / Services ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.venv/
venv/
*.egg-info/
.eggs/
dist/
build/
htmlcov/
.coverage

# ── Terraform ────────────────────────────────────────────────────────────────
# Downloaded providers — large binaries, never commit
terraform/**/.terraform/

# State files — contain sensitive data, stored in S3 remote backend
terraform/**/terraform.tfstate
terraform/**/terraform.tfstate.backup

# Variable files — may contain secrets
terraform/**/terraform.tfvars
terraform/**/terraform.tfvars.json
*.auto.tfvars

# NOTE: .terraform.lock.hcl IS committed — it pins provider versions (like package-lock.json)

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.sw?

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker ───────────────────────────────────────────────────────────────────
.docker/
